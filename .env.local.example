# Civic AI Tools — API Keys (gitignored)
#
# Copy this file to .env.local and fill in your keys.
# The setup script reads these to configure MCP servers.

# =============================================================================
# NYC Open Data (Socrata) App Token
# =============================================================================
# Optional but recommended — increases rate limits significantly.
# Get yours at: https://data.cityofnewyork.us/profile/edit/developer_settings
# (Requires free NYC Open Data account)
#
# The app token is the "Key ID" value from the developer settings page.
SOCRATA_APP_TOKEN=

# =============================================================================
# Google Data Commons API Key
# =============================================================================
# Required for Data Commons MCP to function.
# Get yours at: https://apikeys.datacommons.org/
#
# The API key is the "api_key" value (not the secret).
DC_API_KEY=
