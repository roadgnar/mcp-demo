# =============================================================================
# MCP Demo — API Keys
# =============================================================================
# Copy this file to .env.local and fill in your keys.
# See SETUP.md for step-by-step instructions on getting each key.
#
# Both keys work for ALL city branches (main, boston, nyc).
# =============================================================================

# Socrata Open Data App Token (Recommended)
# Increases rate limits for NYC Open Data and other Socrata portals.
# Get yours: https://data.cityofnewyork.us/profile/edit/developer_settings
# Use the "Key ID" value (not the Key Secret).
SOCRATA_APP_TOKEN=

# Google Data Commons API Key (Required for demographics)
# Enables population, income, crime, and other statistical data for any US city.
# Get yours: https://apikeys.datacommons.org/
DC_API_KEY=

# Note: Cyvl MCP connects via OAuth — no key needed here.
# Note: Boston CKAN MCP has no authentication — auto-connects.
