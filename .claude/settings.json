{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__cyvl__*",
      "mcp__boston__*",
      "mcp__socrata__*",
      "mcp__data-commons__*",
      "mcp__claude_ai_Cyvl__*",
      "mcp__claude_ai_Boston_CIO_MCP__*",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)"
    ]
  },
  "enableAllProjectMcpServers": true
}
